<view class="container">
  <view wx:if="{{items.length===0}}" class="text-center text-muted" style="padding:120rpx 0;">暂无记录</view>
  <view wx:for="{{items}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="toggleItem">
    <view style="display:flex;justify-content:space-between;align-items:flex-start;">
      <view>
        <text style="font-weight:600;">{{item.primary_gua}}</text>
        <text class="text-muted"> → {{item.changing_gua}}</text>
        <text wx:if="{{item.nickname}}" class="text-muted" style="font-size:24rpx;margin-left:8rpx;">— {{item.nickname}}</text>
      </view>
      <text class="text-muted" style="font-size:22rpx;">{{item.created_at.slice(0,10)}}</text>
    </view>
    <text class="text-muted" style="display:block;margin-top:8rpx;">问：{{item.question}}</text>

    <view wx:if="{{expandedId===item.id}}" style="margin-top:16rpx;padding-top:16rpx;border-top:1rpx solid #E0D6C8;">
      <view wx:if="{{needsTranslation(item) && !translatingMap[item.id]}}"
        style="margin-bottom:12rpx;padding:12rpx;border-radius:8rpx;display:flex;align-items:center;justify-content:space-between;gap:8rpx;background:rgba(139,69,19,0.08);border:1rpx solid rgba(139,69,19,0.2);">
        <text style="font-size:22rpx;color:#8B4513;">
          {{item.lang === 'zh' ? '⚠ 此解读以中文生成' : '⚠ This reading was generated in English'}}
        </text>
        <button bindtap="doTranslate" data-id="{{item.id}}" data-lang="{{item.lang}}"
          style="font-size:22rpx;padding:4rpx 12rpx;border-radius:20rpx;border:1rpx solid rgba(139,69,19,0.4);color:#8B4513;background:transparent;">
          {{translatingMap[item.id] ? '翻译中...' : (item.lang === 'zh' ? '→ EN' : '→ 中文')}}
        </button>
      </view>
      <!-- 卦象爻线 -->
      <view wx:if="{{item.primary_yao}}" style="display:flex;gap:24rpx;justify-content:center;margin-bottom:16rpx;">
        <view style="text-align:center;">
          <text style="font-size:24rpx;color:#9E8C7A;display:block;margin-bottom:4rpx;">本卦</text>
          <text style="font-size:28rpx;font-weight:700;color:#8B4513;display:block;margin-bottom:8rpx;">{{item.primary_gua}}</text>
          <view style="display:flex;flex-direction:column;align-items:center;gap:4rpx;">
            <view wx:for="{{hexLines(item.primary_yao, item.yao_positions)}}" wx:for-item="l" wx:key="pos" style="display:flex;align-items:center;justify-content:center;height:12rpx;">
              <view wx:if="{{l.yang}}" style="width:64rpx;height:6rpx;border-radius:2rpx;background:{{l.changing ? '#C62828' : '#5D4037'}};{{l.changing ? 'box-shadow:0 0 6rpx rgba(198,40,40,0.5);' : ''}}"></view>
              <view wx:else style="display:flex;gap:4rpx;">
                <view style="width:28rpx;height:6rpx;border-radius:2rpx;background:{{l.changing ? '#C62828' : '#5D4037'}};{{l.changing ? 'box-shadow:0 0 6rpx rgba(198,40,40,0.5);' : ''}}"></view>
                <view style="width:28rpx;height:6rpx;border-radius:2rpx;background:{{l.changing ? '#C62828' : '#5D4037'}};{{l.changing ? 'box-shadow:0 0 6rpx rgba(198,40,40,0.5);' : ''}}"></view>
              </view>
            </view>
          </view>
        </view>
        <view style="text-align:center;">
          <text style="font-size:24rpx;color:#9E8C7A;display:block;margin-bottom:4rpx;">变卦</text>
          <text style="font-size:28rpx;font-weight:700;color:#A0522D;display:block;margin-bottom:8rpx;">{{item.changing_gua}}</text>
          <view wx:if="{{item.changing_yao}}" style="display:flex;flex-direction:column;align-items:center;gap:4rpx;">
            <view wx:for="{{hexLines(item.changing_yao, '')}}" wx:for-item="l" wx:key="pos" style="display:flex;align-items:center;justify-content:center;height:12rpx;">
              <view wx:if="{{l.yang}}" style="width:64rpx;height:6rpx;border-radius:2rpx;background:#5D4037;"></view>
              <view wx:else style="display:flex;gap:4rpx;">
                <view style="width:28rpx;height:6rpx;border-radius:2rpx;background:#5D4037;"></view>
                <view style="width:28rpx;height:6rpx;border-radius:2rpx;background:#5D4037;"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <rich-text nodes="{{renderMD(getDisplayText(item))}}"
        style="font-size:26rpx;line-height:1.8;color:#5D4037;"></rich-text>
      <view style="margin-top:12rpx;padding-top:12rpx;border-top:1rpx solid #E0D6C8;text-align:center;">
        <text bindtap="viewDetail" data-id="{{item.id}}" data-lang="{{item.lang}}" data-q="{{item.question}}"
          style="font-size:24rpx;color:#8B4513;">查看完整卦象 →</text>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore}}" class="text-center mt-3">
    <button class="btn-secondary" bindtap="loadMore" loading="{{loading}}">加载更多</button>
  </view>
</view>
