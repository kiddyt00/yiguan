<view class="container">
  <view wx:if="{{items.length===0}}" class="text-center text-muted" style="padding:120rpx 0;">暂无记录</view>
  <view wx:for="{{items}}" wx:key="id" class="card" data-id="{{item.id}}" bindtap="toggleItem">
    <view style="display:flex;justify-content:space-between;align-items:flex-start;">
      <view>
        <text style="font-weight:600;">{{item.primary_gua}}</text>
        <text class="text-muted"> → {{item.changing_gua}}</text>
      </view>
      <text class="text-muted" style="font-size:22rpx;">{{item.created_at.slice(0,10)}}</text>
    </view>
    <text class="text-muted" style="display:block;margin-top:8rpx;">问：{{item.question}}</text>
    <view wx:if="{{expandedId===item.id}}" style="margin-top:16rpx;padding-top:16rpx;border-top:1rpx solid #E0D6C8;">
      <rich-text nodes="{{renderMD(item.interpretation)}}" style="font-size:26rpx;line-height:1.8;color:#5D4037;"></rich-text>
    </view>
  </view>
  <view wx:if="{{hasMore}}" class="text-center mt-3">
    <button class="btn-secondary" bindtap="loadMore" loading="{{loading}}">加载更多</button>
  </view>
</view>
