.toss-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}
.toss-label {
  font-size: 26rpx;
  font-weight: 600;
  width: 60rpx;
  color: #5D4037;
}
.coin-group {
  display: flex;
  gap: 8rpx;
}
.coin {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}
.coin-front {
  background: rgba(139,69,19,0.8);
  color: #FFF8DC;
}
.coin-back {
  background: #D4C5A9;
  color: #5D4037;
}
.toss-sum {
  font-size: 24rpx;
  color: #9E8C7A;
}
.toss-type {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}
.toss-normal {
  background: #E8DCC8;
  color: #5D4037;
}
.toss-changing {
  background: rgba(198,40,40,0.15);
  color: #C62828;
  font-weight: 600;
}
/* 阴阳爻线 */
.yao-line {
  margin-left: auto;
  min-width: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
.yang-line {
  width: 48rpx;
  height: 8rpx;
  background: #5D4037;
  border-radius: 4rpx;
}
.yang-line.changing {
  background: #C62828;
  box-shadow: 0 0 8rpx rgba(198,40,40,0.5);
}
.yin-lines {
  display: flex;
  gap: 8rpx;
  align-items: center;
}
.yin-seg {
  width: 20rpx;
  height: 8rpx;
  background: #5D4037;
  border-radius: 4rpx;
}
.yin-seg.changing {
  background: #C62828;
  box-shadow: 0 0 8rpx rgba(198,40,40,0.5);
}
