<view class="container">
  <view class="text-center mb-3" style="padding-top:60rpx;">
    <text style="font-size:80rpx;">☯</text>
    <view style="font-size:44rpx;font-weight:700;margin-top:16rpx;">观己斋</view>
    <text class="text-muted" style="display:block;margin-top:8rpx;">观易知变，见心明境</text>
  </view>

  <view wx:if="{{!hasToken}}">
    <view class="card text-center">
      <button class="btn-primary" style="width:100%;background:#07C160;" loading="{{wxLoading}}" bindtap="wechatLogin">
        📱 微信一键登录
      </button>
      <text class="text-muted" style="display:block;margin-top:8rpx;">授权后自动创建账号，无需注册</text>
    </view>
    <view style="display:flex;align-items:center;margin:24rpx 0;">
      <view style="flex:1;height:1rpx;background:#E0D6C8;"></view>
      <text class="text-muted" style="margin:0 24rpx;">或</text>
      <view style="flex:1;height:1rpx;background:#E0D6C8;"></view>
    </view>
    <view style="display:flex;border-bottom:1rpx solid #E0D6C8;margin-bottom:24rpx;">
      <view class="tab-btn {{activeTab==='短信登录'?'tab-active':''}}" catchtap="switchTab" data-tab="短信登录">短信登录</view>
      <view class="tab-btn {{activeTab==='密码登录'?'tab-active':''}}" catchtap="switchTab" data-tab="密码登录">密码登录</view>
    </view>
    <view wx:if="{{activeTab==='短信登录'}}" class="card" style="margin-bottom:0;">
      <view style="display:flex;gap:16rpx;margin-bottom:24rpx;">
        <input type="number" value="{{phone}}" bindinput="onPhone" placeholder="手机号" maxlength="11" class="input-field" style="flex:1;" />
        <button class="btn-secondary" style="padding:12rpx 24rpx;font-size:24rpx;white-space:nowrap;" disabled="{{sendDisabled}}" bindtap="sendSMS">{{sendText}}</button>
      </view>
      <input type="number" value="{{code}}" bindinput="onCode" placeholder="验证码" maxlength="6" class="input-field" style="margin-bottom:32rpx;" />
      <button class="btn-primary" style="width:100%;" loading="{{smsLoading}}" bindtap="smsLogin">登录 / 注册</button>
    </view>
    <view wx:if="{{activeTab==='密码登录'}}">
      <view class="card" style="margin-bottom:0;">
        <input type="number" value="{{pwdPhone}}" bindinput="onPwdPhone" placeholder="手机号" maxlength="11" class="input-field" style="margin-bottom:24rpx;" />
        <input type="text" password="{{true}}" value="{{password}}" bindinput="onPassword" placeholder="密码" class="input-field" style="margin-bottom:32rpx;" />
        <view wx:if="{{isRegister}}">
          <input value="{{regNickname}}" bindinput="onNick" placeholder="昵称（选填）" class="input-field" style="margin-bottom:24rpx;" />
        </view>
        <view wx:if="{{pwdError}}" style="font-size:24rpx;color:#C62828;text-align:center;margin-bottom:12rpx;">{{pwdError}}</view>
        <button class="btn-primary" style="width:100%;" loading="{{pwdLoading}}" bindtap="pwdSubmit">{{isRegister ? '注册' : '登录'}}</button>
        <view class="text-center mt-3">
          <text class="text-muted" catchtap="toggleMode">{{isRegister ? '已有账号？去登录' : '没有账号？去注册'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{hasToken}}">
    <view class="text-center mb-3">
      <text wx:if="{{nickname}}" style="font-size:30rpx;font-weight:600;color:#5D4037;display:block;margin-bottom:8rpx;">{{nickname}}</text>
      <text wx:if="{{quota>=0}}" style="font-size:26rpx;color:{{quota>0?'#9E8C7A':'#C62828'}};">
        {{quota>0 ? '剩余 '+quota+' 次提问' : '次数已用完'}}
      </text>
    </view>
    <view class="card">
      <view style="font-size:30rpx;font-weight:600;margin-bottom:16rpx;">请默想你的问题：</view>
      <textarea value="{{question}}" bindinput="onInput" placeholder="例如：最近有些迷茫，想听听《周易》的启发..." maxlength="200" style="width:100%;height:160rpx;font-size:28rpx;line-height:1.6;"></textarea>
      <view class="flex gap-2 mt-3">
        <button class="btn-secondary" style="flex:1;" bindtap="goHistory">历史记录</button>
        <button class="btn-primary" style="flex:2;" disabled="{{!question || quota<=0}}" bindtap="startDivine">{{loading ? '起卦中...' : '开始提问'}}</button>
      </view>
    </view>
  </view>

  <view class="flex gap-2" style="justify-content:center;">
    <text class="text-muted" bindtap="goUser">个人中心</text>
    <text class="text-muted">|</text>
    <text class="text-muted" bindtap="goAds">📢 看广告领次数</text>
    <text class="text-muted">|</text>
    <text class="text-muted" bindtap="goAbout">关于我们</text>
  </view>

  <view class="card text-center mt-3" bindtap="toggleMaster">
    <text style="font-size:28rpx;color:#8B4513;">🎓 周易大师一对一详解</text>
  </view>

  <view wx:if="{{showMaster}}" class="card text-center mt-3">
    <text style="font-size:30rpx;font-weight:600;">周易大师 · 一对一深度交流</text>
    <image src="/images/master-qr.svg" mode="widthFix" style="width:400rpx;margin:24rpx auto;"></image>
    <text class="text-muted">长按识别二维码添加大师微信</text>
    <button class="btn-secondary mt-3" bindtap="toggleMaster">关闭</button>
  </view>
</view>
