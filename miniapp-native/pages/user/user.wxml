<view class="container">
  <view class="card text-center" style="padding-top:48rpx;">
    <image src="/images/default-avatar.svg" mode="aspectFill" style="width:120rpx;height:120rpx;border-radius:60rpx;margin:0 auto;"></image>
    <view style="font-size:36rpx;font-weight:700;margin-top:16rpx;">{{profile.nickname || '易友'}}</view>
    <text class="text-muted">{{profile.phone || ''}}</text>
  </view>
  <view class="card">
    <view style="font-size:28rpx;font-weight:600;margin-bottom:16rpx;">编辑资料</view>
    <input value="{{form.nickname}}" bindinput="onNick" placeholder="昵称" class="input-field" style="margin-bottom:16rpx;" />
    <input value="{{form.address}}" bindinput="onAddr" placeholder="地址（选填）" class="input-field" style="margin-bottom:24rpx;" />
    <button class="btn-primary" style="width:100%;" bindtap="save">保存</button>
  </view>
  <button class="btn-secondary mt-3" style="width:100%;" bindtap="logout">退出登录</button>
</view>
