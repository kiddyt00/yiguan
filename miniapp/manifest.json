{
  "name": "观己斋",
  "appid": "wx9e87b7216be83619",
  "description": "观易知变，见心明境。AI 驱动的周易占筮平台。",
  "versionName": "1.0",
  "versionCode": "100",
  "locale": "zh_CN",
  "uniStatistics": { "enable": false },
  "mp-weixin": {
    "appid": "wx9e87b7216be83619",
    "setting": {
      "urlCheck": false,
      "es6": true,
      "postcss": true,
      "minified": true
    },
    "usingComponents": true,
    "permission": {
      "scope.userLocation": { "desc": "你的位置信息将用于本地化服务" }
    },
    "requiredPrivateInfos": ["getPhoneNumber", "onLocationChange"],
    "darkmode": false,
    "themeLocation": "",
    "networkTimeout": {
      "request": 30000,
      "connectSocket": 60000,
      "uploadFile": 60000,
      "downloadFile": 60000
    },
    "preloadRule": {
      "pages/result/result": { "network": "all", "packages": ["__APP__"] }
    }
  }
}
